---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Newsletter from "../components/Newsletter.astro";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <Header />
  <main class="container-article py-16 animate-fade-in-up">
    <a
      href={`/categories/${post.data.category}`}
      class="inline-block px-3 py-1 rounded-full text-xs font-medium uppercase tracking-wider border border-border-default text-text-secondary hover:text-accent-primary hover:border-accent-primary transition-all duration-150 mb-6"
    >
      {post.data.category.replace("-", " ")}
    </a>

    <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">{post.data.title}</h1>
    <p class="text-xl text-text-secondary mb-6">{post.data.description}</p>

    <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted mb-10 pb-6 border-b border-border-default">
      <span class="text-text-primary font-medium">{post.data.author}</span>
      <span class="text-text-muted">·</span>
      <time datetime={post.data.publishDate.toISOString()}>
        {new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(post.data.publishDate)}
      </time>
      <span class="text-text-muted">·</span>
      <span>{post.data.readingTime || "5 min read"}</span>
      <div class="flex gap-2 ml-auto">
        {post.data.tags.map((tag) => (
          <span class="px-2 py-0.5 rounded text-xs bg-bg-card text-text-muted border border-border-default">#{tag}</span>
        ))}
      </div>
    </div>

    {post.data.image && (
      <img src={post.data.image} alt={post.data.title} class="w-full rounded-xl mb-10 border border-border-default" />
    )}

    <article class="prose"><Content /></article>

    <div class="mt-12 p-6 rounded-xl bg-bg-card border border-border-default">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-bg-hover flex items-center justify-center text-accent-primary font-bold text-xl">KJ</div>
        <div>
          <p class="font-semibold text-text-primary">Ketan Jawale</p>
          <p class="text-sm text-text-muted">Digital Marketing enthusiast. Sharing insights on SEO, social media, content strategy, PPC, and analytics — all for free.</p>
        </div>
      </div>
    </div>

    <div class="mt-12 p-6 rounded-xl bg-bg-card border border-border-default">
      <h3 class="text-lg font-semibold mb-4">Comments</h3>
      <p class="text-sm text-text-muted">Comments powered by GitHub Discussions. Sign in with GitHub to leave a comment.</p>
    </div>

    <div class="mt-10"><Newsletter /></div>
  </main>
  <Footer />
</BaseLayout>
