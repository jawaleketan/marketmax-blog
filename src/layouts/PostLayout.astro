---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Newsletter from "../components/Newsletter.astro";
import BlogCard from "../components/BlogCard.astro";
import { render, getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts: same category, exclude current, take 3
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <!-- Article JSON-LD Schema -->
  <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "${post.data.title}",
      "description": "${post.data.description}",
      "datePublished": "${post.data.publishDate.toISOString()}",
      "author": {
        "@type": "Person",
        "name": "${post.data.author}"
      },
      "publisher": {
        "@type": "Person",
        "name": "Ketan Jawale"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://marketmax-blog.netlify.app/blog/${post.id}"
      }${post.data.image ? `,
      "image": "${post.data.image}"` : ``}
    }
  `} />
  <Header />
  <main class="container-article py-16 animate-fade-in-up">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-accent-primary transition-colors mb-8 group">
      <svg class="w-4 h-4 transition-transform duration-150 group-hover:-translate-x-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Back to All Articles
    </a>

    <a
      href={`/categories/${post.data.category}`}
      class="inline-block px-3 py-1 rounded-full text-xs font-medium uppercase tracking-wider border border-border-default text-text-secondary hover:text-accent-primary hover:border-accent-primary transition-all duration-150 mb-6"
    >
      {post.data.category.replace("-", " ")}
    </a>

    <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">{post.data.title}</h1>
    <p class="text-xl text-text-secondary mb-6">{post.data.description}</p>

    <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted mb-10 pb-6 border-b border-border-default">
      <span class="text-text-primary font-medium">{post.data.author}</span>
      <span class="text-text-muted">·</span>
      <time datetime={post.data.publishDate.toISOString()}>
        {new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(post.data.publishDate)}
      </time>
      <span class="text-text-muted">·</span>
      <span>{post.data.readingTime || "5 min read"}</span>
      <div class="flex gap-2 ml-auto">
        {post.data.tags.map((tag) => (
          <span class="px-2 py-0.5 rounded text-xs bg-bg-card text-text-muted border border-border-default">#{tag}</span>
        ))}
      </div>
    </div>

    {post.data.image && (
      <img src={post.data.image} alt={post.data.title} class="w-full rounded-xl mb-10 border border-border-default" />
    )}

    <article class="prose"><Content /></article>

    <div class="mt-12 p-6 rounded-xl bg-bg-card border border-border-default">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-bg-hover flex items-center justify-center text-accent-primary font-bold text-xl">KJ</div>
        <div>
          <p class="font-semibold text-text-primary">Ketan Jawale</p>
          <p class="text-sm text-text-muted">Digital Marketing enthusiast. Sharing insights on SEO, social media, content strategy, PPC, and analytics — all for free.</p>
        </div>
      </div>
    </div>

    <div class="mt-12 p-6 rounded-xl bg-bg-card border border-border-default">
      <h3 class="text-lg font-semibold mb-4">Comments</h3>
      <p class="text-sm text-text-muted">Comments powered by GitHub Discussions. Sign in with GitHub to leave a comment.</p>
    </div>

    {relatedPosts.length > 0 && (
      <section class="mt-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-text-muted">Related Articles</h2>
          <a href={`/categories/${post.data.category}`} class="text-sm text-accent-primary hover:text-accent-hover transition-colors">View All →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedPosts.map((related) => <BlogCard post={related} />)}
        </div>
      </section>
    )}

    <div class="mt-10"><Newsletter /></div>
  </main>
  <Footer />
</BaseLayout>
