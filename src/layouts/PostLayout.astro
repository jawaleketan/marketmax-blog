---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Newsletter from "../components/Newsletter.astro";
import BlogCard from "../components/BlogCard.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PopularPosts from "../components/PopularPosts.astro";
import SeriesNav from "../components/SeriesNav.astro";
import Comments from "../components/Comments.astro";
import Reactions from "../components/Reactions.astro";
import BookmarkBtn from "../components/BookmarkBtn.astro";
import { render, getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection("blog");
const sorted = allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const currentIdx = sorted.findIndex((p) => p.id === post.id);
const prevPost = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
const nextPost = currentIdx > 0 ? sorted[currentIdx - 1] : null;

const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "${post.data.title}",
      "description": "${post.data.description}",
      "datePublished": "${post.data.publishDate.toISOString()}",
      "author": {
        "@type": "Person",
        "name": "${post.data.author}"
      },
      "publisher": {
        "@type": "Person",
        "name": "Ketan Jawale"
      },
      "dateModified": "${(post.data.updatedDate || post.data.publishDate).toISOString()}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://marketmax-blog.netlify.app/blog/${post.id}"
      }${post.data.image ? `,
      "image": "${post.data.image}"` : ``}
    }
  `} />
  <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://marketmax-blog.netlify.app/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://marketmax-blog.netlify.app/blog" },
        { "@type": "ListItem", "position": 3, "name": "${post.data.title}", "item": "https://marketmax-blog.netlify.app/blog/${post.id}" }
      ]
    }
  `} />
  <Header />
  <main class="container-article pt-16 pb-16 sm:pt-24 sm:pb-20 animate-fade-in-up" data-post-slug={post.id} data-prev-url={prevPost ? `/blog/${prevPost.id}` : ""} data-next-url={nextPost ? `/blog/${nextPost.id}` : ""}>
    <div class="mb-10"><Breadcrumb items={[
      { href: "/blog", label: "blog" },
      { href: `/categories/${post.data.category}`, label: post.data.category.replace("-", " ") },
      { label: post.data.title },
    ]} /></div>

    <div class="flex items-center gap-3 mb-6">
      <a
        href={`/categories/${post.data.category}`}
        class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded text-[10px] font-mono uppercase tracking-wider border ${(() => {
          const map = {
            seo: "border-tag-seo/25 text-tag-seo hover:bg-tag-seo/10",
            "social-media": "border-tag-social/25 text-tag-social hover:bg-tag-social/10",
            "content-marketing": "border-tag-content/25 text-tag-content hover:bg-tag-content/10",
            ppc: "border-tag-ppc/25 text-tag-ppc hover:bg-tag-ppc/10",
            analytics: "border-tag-analytics/25 text-tag-analytics hover:bg-tag-analytics/10",
          };
          return map[post.data.category as keyof typeof map] || "border-border-default text-text-muted";
        })()} transition-all duration-150`}
      >
        <span class="w-1 h-1 rounded-full bg-current"></span>
        {post.data.category.replace("-", " ")}
      </a>
    </div>

    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-4">{post.data.title}</h1>
    <p class="text-base sm:text-lg text-text-muted mb-6 leading-relaxed">{post.data.description}</p>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs font-mono text-text-muted mb-8 pb-6 border-b border-border-default">
      <span class="text-text-primary font-medium">{post.data.author}</span>
      <span>/</span>
      <time datetime={post.data.publishDate.toISOString()}>
        {new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(post.data.publishDate)}
      </time>
      <span>/</span>
      <span>{post.data.readingTime || "5 min read"}</span>
      <div class="flex items-center gap-2 ml-auto">
        <span class="flex items-center gap-1 text-text-muted" id="view-count">
          <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="view-count-number" class="skeleton-box">--</span>
        </span>
        {post.data.tags.map((tag) => {
          const slug = tag.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");
          return <a href={`/tags/${slug}`} class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg-card text-text-muted border border-border-default hover:text-accent-primary hover:border-accent-primary/30 transition-colors">#{tag}</a>;
        })}
      </div>
    </div>

    {post.data.image && (
      <div class="aspect-[1200/630] rounded-lg mb-8 overflow-hidden border border-border-default bg-bg-surface">
        <img src={post.data.image} alt={post.data.title} width="1200" height="630" class="w-full h-full object-cover" loading="lazy" decoding="async" />
      </div>
    )}

    <details class="xl:hidden mb-6 rounded-lg border border-border-default bg-bg-card group">
      <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer text-xs font-mono text-text-muted hover:text-text-primary transition-colors select-none [&::-webkit-details-marker]:hidden">
        <svg class="w-3.5 h-3.5 transition-transform duration-150 group-open:rotate-90" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="font-semibold uppercase tracking-widest text-[11px]">On this page</span>
      </summary>
      <div class="px-4 pb-3 border-t border-border-default pt-2">
        <ul class="toc-list text-xs space-y-1.5"></ul>
      </div>
    </details>

    <div class="flex gap-8">
      <nav id="table-of-contents" class="hidden xl:block w-56 flex-shrink-0">
        <div class="sticky top-20 space-y-10">
          <div>
            <p class="text-[11px] font-mono font-semibold uppercase tracking-widest text-text-muted mb-5">On this page</p>
            <ul class="toc-list text-xs space-y-1.5"></ul>
          </div>
          <PopularPosts />
        </div>
      </nav>

      <article class="prose flex-1 min-w-0"><Content /></article>
    </div>

    {post.data.series && <SeriesNav series={post.data.series} allPosts={allPosts} currentSlug={post.id} />}

    <div class="mt-12 mb-10 flex items-center justify-between gap-3">
      <div class="flex-1 p-5 sm:p-6 rounded-lg bg-bg-card border border-border-default">
        <div class="flex items-center gap-4">
          <div class="relative shrink-0">
            <img src="/images/ketan.jpg" alt="Ketan Jawale" width="80" height="80" class="w-20 h-20 rounded-full object-cover border border-border-default" loading="lazy" decoding="async" />
            <a href="https://www.linkedin.com/in/ketanjawale/" target="_blank" rel="noopener noreferrer" class="absolute -bottom-0.5 -right-0.5 w-5 h-5 rounded-full bg-accent-primary text-black flex items-center justify-center hover:bg-accent-hover transition-colors" aria-label="LinkedIn">
              <svg class="w-2 h-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
          <div>
            <p class="text-sm font-semibold text-text-primary font-mono">Ketan Jawale</p>
            <p class="text-xs font-mono text-text-muted mt-0.5">Digital Marketing enthusiast. Sharing free insights on SEO, social media, content strategy, PPC, and analytics.</p>
          </div>
        </div>
      </div>
      <div class="flex sm:flex-col gap-2">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted text-center">Share</span>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://marketmax-blog.netlify.app/blog/${post.id}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-md border border-border-default text-text-muted hover:text-accent-primary hover:border-accent-primary/30 transition-all" aria-label="Share on Twitter">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v12H4z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://marketmax-blog.netlify.app/blog/${post.id}`)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-md border border-border-default text-text-muted hover:text-accent-primary hover:border-accent-primary/30 transition-all" aria-label="Share on LinkedIn">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <button id="copy-link-btn" data-url={`https://marketmax-blog.netlify.app/blog/${post.id}`} class="w-9 h-9 flex items-center justify-center rounded-md border border-border-default text-text-muted hover:text-accent-primary hover:border-accent-primary/30 transition-all" aria-label="Copy link">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
        <BookmarkBtn />
      </div>
    </div>

    {(prevPost || nextPost) && (
      <div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          {prevPost ? (
            <a href={`/blog/${prevPost.id}`} class="card-hover group p-4 rounded-lg border border-border-default bg-bg-card hover:bg-bg-hover">
              <span class="text-[10px] font-mono text-text-muted">&larr; Previous</span>
              <p class="text-sm font-medium text-text-primary group-hover:text-accent-primary transition-colors mt-1 leading-snug">{prevPost.data.title}</p>
            </a>
          ) : <div></div>}
          {nextPost ? (
            <a href={`/blog/${nextPost.id}`} class="card-hover group p-4 rounded-lg border border-border-default bg-bg-card hover:bg-bg-hover text-right">
              <span class="text-[10px] font-mono text-text-muted">Next &rarr;</span>
              <p class="text-sm font-medium text-text-primary group-hover:text-accent-primary transition-colors mt-1 leading-snug">{nextPost.data.title}</p>
            </a>
          ) : <div></div>}
        </div>
        <p class="text-center text-[10px] font-mono text-text-muted"><kbd class="px-1.5 py-0.5 rounded border border-border-default text-[10px]">j</kbd> prev &middot; <kbd class="px-1.5 py-0.5 rounded border border-border-default text-[10px]">k</kbd> next</p>
      </div>
    )}

    {relatedPosts.length > 0 && (
      <section class="mb-10">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-primary"></span>
            <h2 class="text-[11px] font-mono font-semibold uppercase tracking-widest text-text-muted">Related</h2>
          </div>
          <a href={`/categories/${post.data.category}`} class="text-xs font-mono text-text-muted hover:text-accent-primary transition-colors">view all &rarr;</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedPosts.map((related) => <BlogCard post={related} />)}
        </div>
      </section>
    )}

    <Reactions />
    <Comments />
    <div><Newsletter /></div>
  </main>
  <Footer />

  <script>
    document.addEventListener("astro:page-load", () => {
      const main = document.querySelector("main[data-post-slug]");
      const slug = main ? main.getAttribute("data-post-slug") : "";
      if (!slug) return;

      const controller = new AbortController();
      const { signal } = controller;

      document.addEventListener("astro:before-swap", () => {
        controller.abort();
      }, { once: true });

      fetch("/api/view-count?slug=" + encodeURIComponent(slug))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var el = document.getElementById("view-count-number");
          if (el) el.textContent = data.count || 0;
        })
        .catch(function() {
          var el = document.getElementById("view-count-number");
          if (el) el.textContent = "0";
        });

      fetch("/api/view-count", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug: slug }),
      }).catch(function() {});

      var copyBtn = document.getElementById("copy-link-btn");
      if (copyBtn) {
        copyBtn.addEventListener("click", function() {
          var url = copyBtn.getAttribute("data-url") || window.location.href;
          navigator.clipboard.writeText(url).then(function() {
            var original = copyBtn.innerHTML;
            copyBtn.innerHTML = '<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(function() { copyBtn.innerHTML = original; }, 2000);
          });
        }, { signal });
      }

      document.addEventListener("keydown", function(e) {
        if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
        if (e.key === "k" || e.key === "K") {
          var prevUrl = main ? main.getAttribute("data-prev-url") : "";
          if (prevUrl) window.location.href = prevUrl;
        }
        if (e.key === "j" || e.key === "J") {
          var nextUrl = main ? main.getAttribute("data-next-url") : "";
          if (nextUrl) window.location.href = nextUrl;
        }
      }, { signal });

      var tocLists = document.querySelectorAll(".toc-list");
      var article = document.querySelector(".prose");
      if (tocLists.length > 0 && article) {
        var headings = article.querySelectorAll("h2, h3");
        if (headings.length > 0) {
          headings.forEach(function(h, i) {
            var id = "toc-" + i;
            h.setAttribute("id", id);
            var li = document.createElement("li");
            var a = document.createElement("a");
            a.href = "#" + id;
            a.className = "toc-link block py-0.5 " + (h.tagName === "H3" ? "pl-3 text-[11px]" : "text-xs font-medium");
            a.textContent = h.textContent || "";
            li.appendChild(a);
            tocLists.forEach(function(list) { list.appendChild(li.cloneNode(true)); });
          });

          var desktopLinks = document.querySelectorAll("#table-of-contents .toc-link");
          var updateActive = function() {
            var closest = null;
            var closestDist = Infinity;
            headings.forEach(function(h, i) {
              var rect = h.getBoundingClientRect();
              var dist = Math.abs(rect.top);
              if (dist < closestDist) {
                closestDist = dist;
                closest = i;
              }
            });
            desktopLinks.forEach(function(l, i) {
              l.classList.toggle("active", i === closest);
            });
          };
          updateActive();
          window.addEventListener("scroll", function() {
            requestAnimationFrame(updateActive);
          }, { signal });
        }
      }
    });
  </script>
</BaseLayout>
