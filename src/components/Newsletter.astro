---

<div class="p-8 rounded-xl bg-gradient-to-br from-bg-card to-bg-surface border border-border-default">
  <div class="max-w-lg mx-auto text-center">
    <h3 class="text-xl font-bold text-text-primary mb-2">Get Free Marketing Insights 📬</h3>
    <p class="text-sm text-text-secondary mb-6">No spam. Unsubscribe anytime. Join Ketan's newsletter for weekly digital marketing tips, strategies, and tools.</p>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/YOUR_USERNAME"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.com/YOUR_USERNAME', 'popupwindow')"
      class="flex flex-col sm:flex-row gap-3"
    >
      <input type="email" name="email" placeholder="you@example.com" required
        class="flex-1 px-4 py-3 rounded-lg bg-bg-base border border-border-default text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent-primary focus:ring-1 focus:ring-accent-primary transition-all duration-150 text-sm" />
      <button type="submit" class="px-6 py-3 rounded-lg bg-accent-primary text-black font-semibold text-sm hover:bg-accent-hover transition-all duration-150 whitespace-nowrap">Subscribe Free</button>
    </form>
    <p class="mt-3 text-xs text-text-muted">Free forever. No credit card required.</p>
  </div>
</div>
