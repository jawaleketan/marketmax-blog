      <li><a href="/categories/social-media" class="hover:underline">$ cd social-media</a></li>
      <li><a href="/categories/content-marketing" class="hover:underline">$ cd content-marketing</a></li>
      <li><a href="/categories/ppc" class="hover:underline">$ cd ppc</a></li>
      <li><a href="/categories/analytics" class="hover:underline">$ cd analytics</a></li>
