---

<footer class="border-t border-border-default mt-16">
  <div class="container-blog py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="text-lg font-bold text-text-primary"><span class="text-accent-primary">M</span>arketMax</a>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">Free digital marketing insights — SEO, social media, content strategy, PPC, and analytics. No fluff, just value.</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Categories</h4>
        <div class="flex flex-col gap-2">
          <a href="/categories/seo" class="text-sm text-text-muted hover:text-text-primary transition-colors">SEO</a>
          <a href="/categories/social-media" class="text-sm text-text-muted hover:text-text-primary transition-colors">Social Media</a>
          <a href="/categories/content-marketing" class="text-sm text-text-muted hover:text-text-primary transition-colors">Content Marketing</a>
          <a href="/categories/ppc" class="text-sm text-text-muted hover:text-text-primary transition-colors">PPC</a>
          <a href="/categories/analytics" class="text-sm text-text-muted hover:text-text-primary transition-colors">Analytics</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Connect</h4>
        <div class="flex flex-col gap-2">
          <a href="/about" class="text-sm text-text-muted hover:text-text-primary transition-colors">About Ketan</a>
          <a href="/rss.xml" class="text-sm text-text-muted hover:text-text-primary transition-colors">RSS Feed</a>
          <a href="#" class="text-sm text-text-muted hover:text-text-primary transition-colors">Twitter / X</a>
          <a href="#" class="text-sm text-text-muted hover:text-text-primary transition-colors">LinkedIn</a>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-border-default text-center text-xs text-text-muted">
      &copy; {new Date().getFullYear()} MarketMax. Built with Astro. All content free and open.
    </div>
  </div>
</footer>
