---

<section class="container-blog pt-20 pb-16 sm:pt-28 sm:pb-20">
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <div class="flex-1 min-w-0">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-accent-subtle border border-accent-primary/20 text-xs font-medium text-accent-primary mb-6 font-mono">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-primary"></span>
        DIGITAL MARKETING BLOG
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
        Digital Marketing
        <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-primary via-amber-300 to-rose-400">
          Made Simple
        </span>
      </h1>

      <p class="mt-5 text-base sm:text-lg text-text-secondary max-w-xl leading-relaxed">
        Actionable insights on SEO, social media, content marketing, PPC, and analytics — written by Ketan Jawale. No jargon, no fluff.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="/blog" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-primary text-black font-semibold text-sm hover:bg-accent-hover transition-all duration-150 hover:-translate-y-0.5 active:translate-y-0">
          <span class="font-mono">$</span>
          <span>read latest posts</span>
          <span class="terminal-cursor"></span>
        </a>
        <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border-default text-text-secondary hover:text-text-primary hover:border-border-accent transition-all duration-150 text-sm font-mono hover:-translate-y-0.5 active:translate-y-0">
          about.md
        </a>
      </div>


    </div>

    <div class="hidden lg:block flex-shrink-0">
      <pre class="ascii-art text-right select-none" aria-hidden="true">
    __  ___            _          __  __            _
   /  |/  /___ _   _  /_\   ___  |  \/  | __ _ _ __ | |_ ___
  / /|_/ // __| | | |//_\\ / __| | |\/| |/ _` | '_ \| __/ __|
 / /  / / \__ \ |_| / ___ \\__ \ | |  | | (_| | | | | |_\__ \
/_/  /_/  |___/\__,/_/   \_\___/ |_|  |_|\__,_|_| |_|\__|___/
               |___/
      </pre>
    </div>
  </div>
</section>
