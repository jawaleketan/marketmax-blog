---

<section class="container-blog pt-24 pb-10 sm:pt-28 sm:pb-12 overflow-hidden">
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <div class="flex-1 min-w-0">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent-subtle border border-accent-primary/15 text-[11px] font-medium text-accent-primary mb-6 font-mono hero-fade-in" style="animation-delay: 0.1s">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-primary hero-pulse"></span>
        DIGITAL MARKETING BLOG
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.08] tracking-[-0.03em] hero-fade-in" style="animation-delay: 0.2s">
        Digital Marketing
        <br />
        <span class="text-accent-primary">Made Simple</span>
      </h1>

      <p class="mt-5 text-base sm:text-lg text-text-secondary max-w-xl leading-relaxed hero-fade-in" style="animation-delay: 0.35s">
        Actionable insights on SEO, social media, content marketing, PPC, and analytics, written by Ketan Jawale. No jargon, no fluff.
      </p>

      <div class="mt-8 mb-8 sm:mb-12 flex flex-wrap items-center gap-3 hero-fade-in" style="animation-delay: 0.5s">
        <a href="/blog" class="btn-primary font-mono text-xs">
          <span>$</span>
          <span>read latest posts</span>
          <span class="terminal-cursor"></span>
        </a>
        <a href="/about" class="btn-secondary font-mono text-xs">
          about.md
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-4 text-xs font-mono text-text-muted hero-fade-in" style="animation-delay: 0.65s">
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-tag-seo"></span>
          <span>SEO</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-tag-social"></span>
          <span>Social</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-tag-content"></span>
          <span>Content</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-tag-ppc"></span>
          <span>PPC</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-tag-analytics"></span>
          <span>Analytics</span>
        </div>
      </div>
    </div>

    <div class="hidden lg:block flex-shrink-0 hero-fade-in" style="animation-delay: 0.3s">
      <div class="hero-terminal relative w-80 rounded-2xl border border-border-default bg-bg-card overflow-hidden shadow-2xl shadow-black/40">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-default bg-bg-surface">
          <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
          <span class="ml-2 text-[10px] font-mono text-text-muted">marketmax ~$</span>
        </div>
        <div class="p-4 font-mono text-xs leading-relaxed">
          <div class="text-text-muted"><span class="text-accent-primary">$</span> cat stats.md</div>
          <div class="mt-3 space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-text-muted">posts published</span>
              <span class="text-accent-primary font-semibold hero-type-in" style="animation-delay: 1s">9+</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">topics covered</span>
              <span class="text-tag-seo font-semibold hero-type-in" style="animation-delay: 1.2s">5</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">reading time</span>
              <span class="text-tag-social font-semibold hero-type-in" style="animation-delay: 1.4s">~5 min</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">price</span>
              <span class="text-tag-content font-semibold hero-type-in" style="animation-delay: 1.6s">$0.00</span>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border-default text-text-muted">
            <span class="text-accent-primary">$</span> <span class="hero-blink-cursor">_</span>
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-accent-primary/5 via-transparent to-transparent pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>
