---
import type { CollectionEntry } from "astro:content";

export interface Props { post: CollectionEntry<"blog">; featured?: boolean; }

const { post, featured = false } = Astro.props;

type Category = "seo" | "social-media" | "content-marketing" | "ppc" | "analytics";

const categoryColors: Record<Category, string> = {
  seo: "bg-tag-seo/10 text-tag-seo border-tag-seo/30",
  "social-media": "bg-tag-social/10 text-tag-social border-tag-social/30",
  "content-marketing": "bg-tag-content/10 text-tag-content border-tag-content/30",
  ppc: "bg-tag-ppc/10 text-tag-ppc border-tag-ppc/30",
  analytics: "bg-tag-analytics/10 text-tag-analytics border-tag-analytics/30",
};

const categoryLabels: Record<Category, string> = {
  seo: "SEO", "social-media": "Social Media", "content-marketing": "Content Marketing", ppc: "PPC", analytics: "Analytics",
};
---

<article class={`group relative rounded-xl border border-border-default bg-bg-card overflow-hidden transition-all duration-200 hover:bg-bg-hover hover:border-accent-primary/30 hover:shadow-sm hover:shadow-accent-primary/5 hover:-translate-y-1 ${featured ? "md:col-span-2 lg:col-span-2" : ""}`}>
  <a href={`/blog/${post.id}`} class="block p-6">
    <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium uppercase tracking-wider border ${categoryColors[post.data.category as Category] || "bg-bg-hover text-text-muted border-border-default"}`}>
      {categoryLabels[post.data.category as Category] || post.data.category}
    </span>
    <h3 class={`mt-3 font-bold text-text-primary group-hover:text-accent-primary transition-colors duration-150 ${featured ? "text-2xl" : "text-lg"}`}>
      {post.data.title}
    </h3>
    <p class={`mt-2 text-text-muted ${featured ? "text-base" : "text-sm"}`}>{post.data.description}</p>
    <div class="mt-4 flex items-center gap-3 text-xs text-text-muted">
      <time datetime={post.data.publishDate.toISOString()}>
        {new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(post.data.publishDate)}
      </time>
      <span>·</span>
      <span>{post.data.readingTime || "5 min read"}</span>
    </div>
  </a>
</article>
