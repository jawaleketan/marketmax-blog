---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getSupabaseServerClient } from "../../../lib/supabase";

export const prerender = false;

const supabase = getSupabaseServerClient();

const { data: subscribers, count } = await supabase
  .from("subscribers")
  .select("*")
  .order("created_at", { ascending: false });

const confirmedCount = subscribers?.filter(s => s.confirmed).length || 0;
const pendingCount = (count || 0) - confirmedCount;
---

<AdminLayout title="Subscribers">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <h1 style="font-size:24px;font-weight:800;color:var(--color-text-primary);margin:0;letter-spacing:-0.03em;">Subscribers</h1>
    <button onclick="exportCSV()" style="padding:8px 16px;border-radius:8px;border:1px solid var(--color-border-default);background:var(--color-bg-card);color:var(--color-text-primary);font-size:13px;cursor:pointer;font-family:inherit;">Export CSV</button>
  </div>

  <div style="display:flex;gap:16px;margin-bottom:20px;">
    <div style="background:var(--color-bg-card);border:1px solid var(--color-border-default);border-radius:10px;padding:16px;flex:1;">
      <div style="font-size:12px;color:var(--color-text-muted);margin-bottom:4px;">Total</div>
      <div style="font-size:24px;font-weight:800;color:var(--color-text-primary);font-family:monospace;">{count || 0}</div>
    </div>
    <div style="background:var(--color-bg-card);border:1px solid var(--color-border-default);border-radius:10px;padding:16px;flex:1;">
      <div style="font-size:12px;color:var(--color-text-muted);margin-bottom:4px;">Confirmed</div>
      <div style="font-size:24px;font-weight:800;color:#10b981;font-family:monospace;">{confirmedCount}</div>
    </div>
    {pendingCount > 0 && (
      <div style="background:var(--color-bg-card);border:1px solid var(--color-border-default);border-radius:10px;padding:16px;flex:1;">
        <div style="font-size:12px;color:var(--color-text-muted);margin-bottom:4px;">Unconfirmed</div>
        <div style="font-size:24px;font-weight:800;color:#f59e0b;font-family:monospace;">{pendingCount}</div>
      </div>
    )}
  </div>

  {subscribers && subscribers.length > 0 ? (
    <div style="background:var(--color-bg-card);border:1px solid var(--color-border-default);border-radius:10px;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="border-bottom:1px solid var(--color-border-default);">
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Email</th>
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Status</th>
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Subscribed</th>
            <th style="padding:10px 16px;text-align:right;font-size:11px;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {subscribers.map((sub) => (
            <tr style="border-bottom:1px solid var(--color-border-default);">
              <td style="padding:10px 16px;color:var(--color-text-primary);">{sub.email}</td>
              <td style="padding:10px 16px;">
                <span style={`font-size:10px;padding:2px 6px;border-radius:4px;font-weight:600;${sub.confirmed ? "background:rgba(16,185,129,0.1);color:#10b981;" : "background:rgba(245,158,11,0.1);color:#f59e0b;"}`}>
                  {sub.confirmed ? "confirmed" : "pending"}
                </span>
              </td>
              <td style="padding:10px 16px;color:var(--color-text-muted);font-size:12px;">
                {new Date(sub.created_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </td>
              <td style="padding:10px 16px;text-align:right;">
                <button onclick={`deleteSubscriber('${sub.id}')`} style="padding:4px 8px;border-radius:4px;border:1px solid rgba(239,68,68,0.3);background:rgba(239,68,68,0.05);color:#ef4444;font-size:11px;cursor:pointer;font-family:inherit;">Remove</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div style="background:var(--color-bg-card);border:1px solid var(--color-border-default);border-radius:10px;padding:40px;text-align:center;">
      <p style="font-size:14px;color:var(--color-text-muted);margin:0;">No subscribers yet</p>
    </div>
  )}

  <script define:vars={{ subscribersJson: JSON.stringify(subscribers || []) }}>
    function exportCSV() {
      const subs = subscribersJson;
      if (!subs.length) return;
      const csv = "Email,Confirmed,Date\n" + subs.map(s => `${s.email},${s.confirmed},${s.created_at}`).join("\n");
      const blob = new Blob([csv], { type: "text/csv" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "subscribers.csv";
      a.click();
    }

    async function deleteSubscriber(id) {
      if (!confirm("Remove this subscriber?")) return;
      await fetch(`/api/admin/subscribers?id=${id}`, { method: "DELETE" });
      window.location.reload();
    }
  </script>
</AdminLayout>
