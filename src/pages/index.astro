---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import BlogCard from "../components/BlogCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const featuredPost = sortedPosts.find((p) => p.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter((p) => p.id !== featuredPost?.id).slice(0, 6);
---

<BaseLayout title="MarketMax — Digital Marketing Insights" description="Digital marketing blog by Ketan Jawale. Learn SEO, social media, content marketing, PPC, and analytics with actionable guides.">
  <Header />
  <main>
    <Hero />

    {featuredPost && (
      <section class="container-blog mb-14 animate-fade-in-up">
        <div class="flex items-center gap-2 my-6 text-text-muted">
          <span class="text-[11px] font-mono whitespace-nowrap">--- [ Featured ]</span>
          <div class="flex-grow border-t border-dashed border-border-default"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
          <BlogCard post={featuredPost} featured={true} />
        </div>
      </section>
    )}

    <section class="container-blog mb-14 animate-fade-in-up">
      <div class="flex items-center gap-2 my-6 text-text-muted">
        <span class="text-[11px] font-mono whitespace-nowrap">--- [ Categories ]</span>
        <div class="flex-grow border-t border-dashed border-border-default"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {(["seo", "social-media", "content-marketing", "ppc", "analytics"] as const).map((cat) => {
          const count = allPosts.filter((p) => p.data.category === cat).length;
          const labels = { seo: "SEO", "social-media": "Social", "content-marketing": "Content", ppc: "PPC", analytics: "Analytics" };
          const colors = {
            seo: "border-tag-seo/25 text-tag-seo bg-tag-seo/5 hover:bg-tag-seo/10",
            "social-media": "border-tag-social/25 text-tag-social bg-tag-social/5 hover:bg-tag-social/10",
            "content-marketing": "border-tag-content/25 text-tag-content bg-tag-content/5 hover:bg-tag-content/10",
            ppc: "border-tag-ppc/25 text-tag-ppc bg-tag-ppc/5 hover:bg-tag-ppc/10",
            analytics: "border-tag-analytics/25 text-tag-analytics bg-tag-analytics/5 hover:bg-tag-analytics/10",
          };
          return (
            <a href={`/categories/${cat}`} class={`card-hover flex flex-col items-center gap-2 p-5 rounded-lg border ${colors[cat]}`}>
              <span class="text-lg font-bold">{labels[cat]}</span>
              <span class="text-[11px] font-mono opacity-70">{count} post{count !== 1 ? "s" : ""}</span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="container-blog mb-20 animate-fade-in-up">
      <div class="flex items-center gap-2 my-6 text-text-muted">
        <span class="text-[11px] font-mono whitespace-nowrap">--- [ Latest ]</span>
        <div class="flex-grow border-t border-dashed border-border-default"></div>
        <a href="/blog" class="text-[11px] font-mono whitespace-nowrap hover:text-accent-primary transition-colors">view all &rarr;</a>
      </div>
      {recentPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {recentPosts.map((post, i) => (
            <div class={`animate-fade-in-up delay-${Math.min(i + 1, 6)}`}>
              <BlogCard post={post} />
            </div>
          ))}
        </div>
      ) : (
        <div class="col-span-full text-center py-16">
          <p class="text-sm font-mono text-text-muted">No articles yet. Check back soon!</p>
        </div>
      )}
    </section>

    <section class="container-blog pb-20 animate-fade-in-up">
      <div class="flex items-center gap-2 my-6 text-text-muted">
        <span class="text-[11px] font-mono whitespace-nowrap">--- [ Stay Updated ]</span>
        <div class="flex-grow border-t border-dashed border-border-default"></div>
      </div>
      <Newsletter />
    </section>
  </main>
  <Footer />
</BaseLayout>
