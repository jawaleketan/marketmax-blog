---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import BlogCard from "../components/BlogCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";
import { getSupabasePosts } from "../lib/posts";

const [markdownPosts, supabasePosts] = await Promise.all([
  getCollection("blog"),
  getSupabasePosts(),
]);

const allPosts = [...markdownPosts, ...supabasePosts].sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const featuredPost = allPosts.find((p) => p.data.featured) || allPosts[0];
const recentPosts = allPosts.filter((p) => p.id !== featuredPost?.id).slice(0, 6);

const categoryCounts = {
  seo: allPosts.filter((p) => p.data.category === "seo").length,
  "social-media": allPosts.filter((p) => p.data.category === "social-media").length,
  "content-marketing": allPosts.filter((p) => p.data.category === "content-marketing").length,
  ppc: allPosts.filter((p) => p.data.category === "ppc").length,
  analytics: allPosts.filter((p) => p.data.category === "analytics").length,
};
---

<BaseLayout title="MarketMax, Digital Marketing Insights" description="Digital marketing blog by Ketan Jawale. Learn SEO, social media, content marketing, PPC, and analytics with actionable guides.">
  <Header />
  <main class="space-y-2 md:space-y-4">
    <Hero />

    {featuredPost && (
      <section class="container-blog py-6 sm:py-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <BlogCard post={featuredPost} featured={true} />
        </div>
      </section>
    )}

    <section class="container-blog py-6 sm:py-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {(["seo", "social-media", "content-marketing", "ppc", "analytics"] as const).map((cat) => {
          const count = categoryCounts[cat];
          const labels = { seo: "SEO", "social-media": "Social", "content-marketing": "Content", ppc: "PPC", analytics: "Analytics" };
          const colors = {
            seo: "border-tag-seo/20 text-tag-seo bg-tag-seo/5 hover:bg-tag-seo/10",
            "social-media": "border-tag-social/20 text-tag-social bg-tag-social/5 hover:bg-tag-social/10",
            "content-marketing": "border-tag-content/20 text-tag-content bg-tag-content/5 hover:bg-tag-content/10",
            ppc: "border-tag-ppc/20 text-tag-ppc bg-tag-ppc/5 hover:bg-tag-ppc/10",
            analytics: "border-tag-analytics/20 text-tag-analytics bg-tag-analytics/5 hover:bg-tag-analytics/10",
          };
          return (
            <a href={`/categories/${cat}`} class={`card-hover flex flex-col items-center gap-2 p-5 rounded-2xl border ${colors[cat]}`}>
              <span class="text-lg font-bold">{labels[cat]}</span>
              <span class="text-[11px] font-mono opacity-70">{count} post{count !== 1 ? "s" : ""}</span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="container-blog py-6 sm:py-8">
      <div class="flex items-center gap-4 mb-10 text-text-muted font-mono tracking-wider text-xs uppercase">
        <span>--- [ LATEST ]</span>
        <div class="flex-grow border-t border-dashed border-border-default"></div>
        <a href="/blog" class="whitespace-nowrap hover:text-accent-primary transition-colors duration-200">view all &rarr;</a>
      </div>
      {recentPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {recentPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <div class="col-span-full text-center py-16">
          <p class="text-sm font-mono text-text-muted">No articles yet. Check back soon!</p>
        </div>
      )}
    </section>

    <section class="container-blog py-6 sm:py-8">
      <Newsletter />
    </section>
  </main>
  <Footer />
</BaseLayout>
