---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="404 — Not Found" description="Page not found.">
  <Header />
  <main class="container-blog pt-8 pb-20 text-center animate-fade-in-up">
    <div class="max-w-lg mx-auto">
      <div class="inline-flex items-center gap-3 mb-8">
        <span class="text-6xl font-mono font-bold text-accent-primary">404</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight mb-3">Page not found</h1>
      <p class="text-sm font-mono text-text-muted mb-8">The page you're looking for doesn't exist or has moved.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-primary text-black font-semibold text-sm font-mono hover:bg-accent-hover transition-all duration-150">
        <span>$</span> cd ~/home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
